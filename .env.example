# ── SILOCARGO DSV ──────────────────────────────────────────
# URL del sistema SILOCARGO (por defecto: https://dsv.colombiasoftware.net)
SILOCARGO_URL=https://dsv.colombiasoftware.net

# Credenciales de acceso al portal SILOCARGO
SILOCARGO_USER=tu_usuario
SILOCARGO_PASSWORD=tu_contraseña

# ── WEBHOOK TMS ────────────────────────────────────────────
# URL del webhook donde se enviarán las solicitudes nuevas
TMS_WEBHOOK_URL=https://tu-sistema-tms.com/webhook/solicitudes

# ── SERVIDOR ───────────────────────────────────────────────
PORT=3000

# ── CHROMIUM (opcional) ────────────────────────────────────
# Ruta manual a Chromium si la detección automática falla
# CHROMIUM_PATH=/usr/bin/chromium-browser
